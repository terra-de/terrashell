#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

failures=0

check_absent_dir() {
  local dir_path="$1"
  local message="$2"
  if [[ -d "$dir_path" ]]; then
    echo "[FAIL] $message"
    failures=$((failures + 1))
  else
    echo "[PASS] $message"
  fi
}

check_no_match() {
  local pattern="$1"
  local target="$2"
  local message="$3"
  if rg --glob '*.qml' --glob '*.js' --glob '*.ts' "$pattern" "$target" >/dev/null 2>&1; then
    echo "[FAIL] $message"
    rg --glob '*.qml' --glob '*.js' --glob '*.ts' "$pattern" "$target" || true
    failures=$((failures + 1))
  else
    echo "[PASS] $message"
  fi
}

check_absent_dir "modules" "Legacy modules/ directory removed"
check_absent_dir "components" "Legacy components/ directory removed"

check_no_match 'import\s+".*modules' "." "No imports from modules paths"
check_no_match 'import\s+"(\.\./)+components' "." "No imports from removed top-level components paths"
check_no_match 'Process\s*\{' "app config design features" "No Process usage outside services"
check_no_match '\.exec\(' "app config design features" "No command exec outside services"

if [[ "$failures" -gt 0 ]]; then
  echo "Architecture guard failed with $failures violation(s)."
  exit 1
fi

echo "Architecture guard passed."
